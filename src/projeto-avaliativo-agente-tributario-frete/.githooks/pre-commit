#!/bin/sh
echo "[pre-commit] Rodando pytest..."
cd src/projeto-avaliativo-agente-tributario-frete
.venv/Scripts/python.exe -m pytest tests/ -q --tb=short 2>&1
STATUS=$?
if [ $STATUS -ne 0 ]; then
  echo "[pre-commit] FALHOU — commit bloqueado. Corrija os testes antes de commitar."
  exit 1
fi
echo "[pre-commit] Testes passando. Commit permitido."
exit 0
